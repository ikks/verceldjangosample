{
  "builds": [
    {
      "src": "api/wsgi",
      "use": "@vercel/python",
      "config":
      {
        "maxLambdaSize": "15mb",
        "runtime": "python3.14",
        "buildCommand": "bash setup.sh"
      }
    }
  ],
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "/staticfiles/favicon.ico"
    },
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/wsgi.py"
    }
  ]
}
